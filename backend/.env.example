# Server Configuration
PORT=3000
DATABASE_URL="file:./dev.db" # Replace with your actual database connection string

# Security
JWT_SECRET="change-this-to-a-secure-random-secret"
JWT_EXPIRES_IN="7d"

# Notifications (Toggle as needed)
EMAIL_NOTIFICATIONS_ENABLED=true
SMS_NOTIFICATIONS_ENABLED=true

# Email Provider (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=alerts@mosestalimited.co.ke

# SMS Provider (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Alert Contacts
OPERATOR_PHONE=
DISTRIBUTOR_PHONE=